# agents.keyra.ie — environment variables
#
# Railway (recommended): add a Postgres plugin, then set:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
#   NODE_ENV=production
#
# On Railway, `scripts/railway-start.sh` runs `prisma db push` + seed at container
# start (not during build), so a fresh Postgres database is populated on first boot.

# Production / Railway (Postgres — required; schema uses provider postgresql)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/railway?schema=public"

# Optional: direct (non-pooler) URL for prisma db push on Railway — use if push fails:
# DIRECT_DATABASE_URL=${{Postgres.DATABASE_PRIVATE_URL}}

# Local development (Docker Postgres example):
#   docker run -d --name agents-keyra-pg -e POSTGRES_PASSWORD=postgres -p 5433:5432 postgres:16
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5433/railway?schema=public"
